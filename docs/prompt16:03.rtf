### lib/services/auth_service.dart (interface abstrata)\
```dart\
abstract class AuthService extends ChangeNotifier \{\
  UserModel? get currentUser;\
  bool get isAuthenticated;\
  bool get isLoading;\
  String? get errorMessage;\
\
  Future<AuthResult> signIn(\{\
    required String email,\
    required String password,\
  \});\
\
  Future<AuthResult> signUp(\{\
    required String name,\
    required String email,\
    required String password,\
  \});\
\
  Future<void> signOut();\
  Future<void> sendPasswordResetEmail(String email);\
  Future<void> verifyEmail(String token);\
  Future<AuthResult> verifyTwoFactor(String code);\
  Future<void> enableTwoFactor();\
  Future<void> disableTwoFactor(String code);\
  Future<void> updateProfile(UserModel updated);\
  Future<void> restoreSession();\
\}\
\
class AuthResult \{\
  final bool success;\
  final String? errorMessage;\
  final AuthNextStep nextStep; // none | verifyEmail | twoFactor\
\
  const AuthResult(\{\
    required this.success,\
    this.errorMessage,\
    this.nextStep = AuthNextStep.none,\
  \});\
\}\
\
enum AuthNextStep \{ none, verifyEmail, twoFactor \}\
```\
\
### lib/services/mock_auth_service.dart\
```dart\
// Implementa\'e7\'e3o mock completa para desenvolvimento.\
// Simula todos os fluxos sem backend real.\
// SUBSTITUIR por SupabaseAuthService quando conectar o Supabase.\
\
class MockAuthService extends AuthService \{\
\
  // Banco de usu\'e1rios mock em mem\'f3ria\
  final List<Map<String, dynamic>> _mockUsers = [\
    \{\
      'id': 'user_001',\
      'name': 'Carlos Alberto Silva',\
      'email': 'carlos@email.com',\
      'password': 'senha123',\
      'cpf': '123.456.789-00',\
      'company': 'Construtora ABC',\
      'emailVerified': true,\
      'twoFactorEnabled': false,\
      'role': 'student',\
    \}\
  ];\
\
  @override\
  Future<AuthResult> signIn(\{required String email, required String password\}) async \{\
    _setLoading(true);\
    await Future.delayed(const Duration(seconds: 1)); // simula lat\'eancia\
\
    final user = _mockUsers.firstWhereOrNull(\
      (u) => u['email'] == email.toLowerCase().trim(),\
    );\
\
    if (user == null) \{\
      _setError('E-mail n\'e3o encontrado.');\
      return AuthResult(success: false, errorMessage: 'E-mail n\'e3o encontrado.');\
    \}\
\
    if (user['password'] != password) \{\
      _setError('Senha incorreta.');\
      return AuthResult(success: false, errorMessage: 'Senha incorreta.');\
    \}\
\
    if (user['twoFactorEnabled'] == true) \{\
      // Salvar usu\'e1rio pendente de 2FA\
      _pendingUser = UserModel.fromJson(user);\
      _setLoading(false);\
      return AuthResult(success: true, nextStep: AuthNextStep.twoFactor);\
    \}\
\
    await _loginUser(user);\
    return const AuthResult(success: true);\
  \}\
\
  @override\
  Future<AuthResult> signUp(\{\
    required String name,\
    required String email,\
    required String password,\
  \}) async \{\
    _setLoading(true);\
    await Future.delayed(const Duration(seconds: 1));\
\
    final exists = _mockUsers.any(\
      (u) => u['email'] == email.toLowerCase().trim(),\
    );\
\
    if (exists) \{\
      _setError('Este e-mail j\'e1 est\'e1 cadastrado.');\
      return AuthResult(success: false, errorMessage: 'E-mail j\'e1 cadastrado.');\
    \}\
\
    final newUser = \{\
      'id': 'user_$\{DateTime.now().millisecondsSinceEpoch\}',\
      'name': name.trim(),\
      'email': email.toLowerCase().trim(),\
      'password': password,\
      'emailVerified': false, // mock: exigir verifica\'e7\'e3o\
      'twoFactorEnabled': false,\
      'role': 'student',\
    \};\
\
    _mockUsers.add(newUser);\
    await _loginUser(newUser);\
    _setLoading(false);\
\
    // Mock: simular que e-mail de verifica\'e7\'e3o foi enviado\
    return const AuthResult(success: true, nextStep: AuthNextStep.verifyEmail);\
  \}\
\
  @override\
  Future<AuthResult> verifyTwoFactor(String code) async \{\
    await Future.delayed(const Duration(milliseconds: 800));\
    // Mock: c\'f3digo correto \'e9 "123456"\
    if (code == '123456') \{\
      if (_pendingUser != null) \{\
        _currentUser = _pendingUser;\
        _pendingUser = null;\
        await _persistSession(_currentUser!);\
        notifyListeners();\
      \}\
      return const AuthResult(success: true);\
    \}\
    return const AuthResult(\
      success: false,\
      errorMessage: 'C\'f3digo inv\'e1lido. Verifique o app autenticador.',\
    );\
  \}\
\}\
