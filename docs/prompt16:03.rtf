  if (isLoggedIn && authPaths.any((p) => path.startsWith(p))) \{\
    return '/home';\
  \}\
\
  // Se n\'e3o logado tentando acessar \'e1rea protegida\
  if (!isLoggedIn && protectedPaths.any((p) => path.startsWith(p))) \{\
    final destination = Uri.encodeComponent(state.uri.toString());\
    return '/auth/login?redirect=$destination';\
  \}\
\
  return null;\
\},\
